{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "rootDir": "src/token_machine/dashboard/assets/ts",
    "outDir": "src/token_machine/dashboard/assets/js",
    "strict": true,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "removeComments": false
  },
  "include": ["src/token_machine/dashboard/assets/ts/**/*.ts"]
}
